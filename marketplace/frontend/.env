# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# -------------------- SERVER --------------------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# -------------------- DATABASE --------------------
MONGO_URI=mongodb://localhost:27017/marketplace
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/marketplace

# -------------------- REDIS --------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Optional: REDIS_URL=redis://:password@localhost:6379

# -------------------- JWT AUTHENTICATION --------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# -------------------- EMAIL (SMTP) --------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@yourmarketplace.com

# -------------------- CLOUDINARY (Image Upload) --------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -------------------- PAYMENT GATEWAYS --------------------
# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# PayPal (if enabled)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox  # or 'live'

# Paystack (if enabled)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Coinbase (if enabled)
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_WEBHOOK_SECRET=your-webhook-secret

# -------------------- TAX AUTOMATION (TaxJar / Avalara) --------------------
# TaxJar
TAXJAR_API_KEY=your-taxjar-api-key
TAXJAR_ENABLED=false

# Avalara
AVALARA_API_KEY=your-avalara-api-key
AVALARA_API_SECRET=your-avalara-secret
AVALARA_ENABLED=false

# Fallback tax rate (percent) – used when automation is off or fails
TAX_FALLBACK_RATE=8.0

# -------------------- ADVANCED SHIPPING --------------------
# Default shipping origin (seller's default address – used for carrier rates)
DEFAULT_SHIPPING_COUNTRY=US
DEFAULT_SHIPPING_STATE=CA
DEFAULT_SHIPPING_CITY=Los Angeles
DEFAULT_SHIPPING_ZIP=90001
DEFAULT_SHIPPING_STREET=

# UPS API (optional, for real‑time rates)
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_ENABLED=false

# FedEx API
FEDEX_API_KEY=
FEDEX_API_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_ENABLED=false

# USPS API
USPS_USERNAME=
USPS_PASSWORD=
USPS_ENABLED=false

# -------------------- A/B TESTING & PERSONALISATION --------------------
# Session cookie settings (already set in code, but you can override)
SESSION_COOKIE_MAX_AGE=2592000000  # 30 days in milliseconds

# -------------------- WEBHOOKS --------------------
WEBHOOK_RETRY_MAX_ATTEMPTS=5
WEBHOOK_RETRY_DELAY_BASE=60  # seconds, exponential backoff

# -------------------- GDPR --------------------
# Grace period for account deletion (days)
GDPR_DELETION_GRACE_DAYS=30

# -------------------- AFFILIATE MARKETING --------------------
AFFILIATE_DEFAULT_COMMISSION=5  # percentage

# -------------------- CURRENCY CONVERSION --------------------
# OpenExchangeRates API key (optional)
OPEN_EXCHANGE_RATES_API_KEY=your-api-key
BASE_CURRENCY=USD

# -------------------- SENTRY (Error Tracking) --------------------
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# -------------------- LOGGING --------------------
LOG_LEVEL=info  # debug, info, warn, error
REQUEST_LOG_ENABLED=true

# -------------------- MAINTENANCE / FEATURE FLAGS --------------------
ENABLE_MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please check back later.

# -------------------- CRON JOBS --------------------
# Abandoned cart reminder delay (hours)
ABANDONED_CART_DELAY_HOURS=1

# Daily job schedules (cron expressions)
BADGES_UPDATE_CRON=0 2 * * *      # 2 AM daily
SITEMAP_REFRESH_CRON=0 3 * * *    # 3 AM daily
ACCOUNT_DELETION_CRON=0 4 * * *   # 4 AM daily