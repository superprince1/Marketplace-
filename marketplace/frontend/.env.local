# ============================================
# FRONTEND ENVIRONMENT VARIABLES (React)
# ============================================

# -------------------- API --------------------
REACT_APP_API_URL=http://localhost:5000/api
# For production:
# REACT_APP_API_URL=https://yourdomain.com/api

# -------------------- WEBSOCKET (Socket.io) --------------------
REACT_APP_WS_URL=ws://localhost:5000
# Production: wss://yourdomain.com

# -------------------- STRIPE (Client‑side) --------------------
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# -------------------- GOOGLE ANALYTICS (GA4) --------------------
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -------------------- SENTRY (Frontend Error Tracking) --------------------
REACT_APP_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# -------------------- PAYMENT GATEWAY CONFIGURATION --------------------
# PayPal Client ID (if using PayPal Checkout)
REACT_APP_PAYPAL_CLIENT_ID=your-paypal-client-id

# Paystack Public Key
REACT_APP_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Coinbase Commerce (optional)
REACT_APP_COINBASE_API_KEY=your-coinbase-api-key

# -------------------- GOOGLE MAPS / PLACES (for address autocomplete) --------------------
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -------------------- FEATURE FLAGS (enable/disable frontend features) --------------------
REACT_APP_ENABLE_AFFILIATE=true
REACT_APP_ENABLE_GIFT_CARDS=true
REACT_APP_ENABLE_SUBSCRIPTIONS=true
REACT_APP_ENABLE_PREORDER=true
REACT_APP_ENABLE_BUNDLES=true
REACT_APP_ENABLE_SOCIAL_FEATURES=true

# -------------------- A/B TESTING --------------------
REACT_APP_EXPERIMENT_SAMPLE_RATE=0.2  # 20% of users see experiments

# -------------------- CDN / ASSETS --------------------
REACT_APP_CDN_URL=https://cdn.yourdomain.com

# -------------------- DEFAULT LANGUAGE --------------------
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_SUPPORTED_LANGUAGES=en,es,fr,de,it,pt,zh,ja

# -------------------- PWA (Service Worker) --------------------
REACT_APP_ENABLE_SERVICE_WORKER=false