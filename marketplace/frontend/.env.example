# ============================================
# MARKETPLACE FRONTEND - ENVIRONMENT VARIABLES
# ============================================
# Variables must start with REACT_APP_

# API endpoint
REACT_APP_API_URL=http://localhost:5000/api

# WebSocket URL (for Socket.io)
REACT_APP_WS_URL=ws://localhost:5000

# Stripe publishable key (client‑side only)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Google Analytics measurement ID
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN (client‑side)
REACT_APP_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# PayPal client ID (if using PayPal Checkout)
REACT_APP_PAYPAL_CLIENT_ID=your-paypal-client-id

# Paystack public key
REACT_APP_PAYSTACK_PUBLIC_KEY=pk_test_xxxx

# Google Maps API key (for address autocomplete)
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Feature flags
REACT_APP_ENABLE_AFFILIATE=true
REACT_APP_ENABLE_GIFT_CARDS=true
REACT_APP_ENABLE_SUBSCRIPTIONS=true
REACT_APP_ENABLE_PREORDER=true
REACT_APP_ENABLE_BUNDLES=true
REACT_APP_ENABLE_SOCIAL_FEATURES=true

# A/B testing sample rate (0.0 – 1.0)
REACT_APP_EXPERIMENT_SAMPLE_RATE=0.2

# Default and supported languages
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_SUPPORTED_LANGUAGES=en,es,fr,de,it,pt,zh,ja

# CDN base URL (optional)
REACT_APP_CDN_URL=https://cdn.yourdomain.com