# ============================================
# MARKETPLACE BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and update values.
# Never commit .env to version control.

# -------------------- SERVER --------------------
# Node environment: development, staging, production
NODE_ENV=development

# Port the server will listen on
PORT=5000

# Client URL(s) – comma separated for multiple origins (CORS)
CLIENT_URL=http://localhost:3000

# -------------------- DATABASE --------------------
# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/marketplace
# Example for MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/marketplace?retryWrites=true&w=majority

# -------------------- REDIS --------------------
# Redis host, port, and optional password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Alternative: REDIS_URL (overrides host/port/password)
# REDIS_URL=redis://:password@localhost:6379

# -------------------- JWT AUTHENTICATION --------------------
# Secret for signing JWTs (must be strong, at least 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiration (e.g., 7d, 30d, 1h)
JWT_EXPIRE=30d

# -------------------- EMAIL (SMTP) --------------------
# SMTP server configuration (e.g., Gmail, SendGrid, AWS SES)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@yourmarketplace.com

# Optional: Use a transactional email service (Set `EMAIL_PROVIDER=sendgrid`)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# -------------------- CLOUDINARY (Image Upload) --------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -------------------- PAYMENT GATEWAYS --------------------
# Stripe
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# PayPal (if enabled)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox   # sandbox or live

# Paystack (if enabled)
PAYSTACK_SECRET_KEY=sk_test_xxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxx

# Coinbase Commerce (if enabled)
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_WEBHOOK_SECRET=your-webhook-secret

# -------------------- TAX AUTOMATION (TaxJar / Avalara) --------------------
# TaxJar
TAXJAR_API_KEY=your-taxjar-api-key
TAXJAR_ENABLED=false

# Avalara
AVALARA_API_KEY=your-avalara-api-key
AVALARA_API_SECRET=your-avalara-secret
AVALARA_ENABLED=false

# Fallback tax rate (percentage) – used when automation is off or fails
TAX_FALLBACK_RATE=8.0

# -------------------- ADVANCED SHIPPING --------------------
# Default shipping origin (used for carrier rate calculations)
DEFAULT_SHIPPING_COUNTRY=US
DEFAULT_SHIPPING_STATE=CA
DEFAULT_SHIPPING_CITY=Los Angeles
DEFAULT_SHIPPING_ZIP=90001
DEFAULT_SHIPPING_STREET=

# UPS API (optional)
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_ENABLED=false

# FedEx API
FEDEX_API_KEY=
FEDEX_API_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_ENABLED=false

# USPS API
USPS_USERNAME=
USPS_PASSWORD=
USPS_ENABLED=false

# -------------------- A/B TESTING & PERSONALISATION --------------------
# Session cookie max age (milliseconds) – defaults to 30 days
SESSION_COOKIE_MAX_AGE=2592000000

# -------------------- WEBHOOKS --------------------
# Retry settings for failed webhook deliveries
WEBHOOK_RETRY_MAX_ATTEMPTS=5
WEBHOOK_RETRY_DELAY_BASE=60   # seconds (exponential backoff)

# -------------------- GDPR --------------------
# Account deletion grace period (days) – user can cancel within this window
GDPR_DELETION_GRACE_DAYS=30

# -------------------- AFFILIATE MARKETING --------------------
# Default commission percentage for affiliates (if not tier‑based)
AFFILIATE_DEFAULT_COMMISSION=5

# -------------------- CURRENCY CONVERSION (Optional) --------------------
# OpenExchangeRates API key for live currency rates
OPEN_EXCHANGE_RATES_API_KEY=your-api-key
BASE_CURRENCY=USD

# -------------------- SENTRY (Error Tracking) --------------------
# Sentry DSN (Data Source Name) – get from your Sentry project
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# -------------------- LOGGING --------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable request logging (HTTP middleware)
REQUEST_LOG_ENABLED=true

# -------------------- MAINTENANCE / FEATURE FLAGS --------------------
# Enable maintenance mode (all requests return 503)
ENABLE_MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please check back later.

# -------------------- CRON JOBS --------------------
# Delay before sending abandoned cart reminder (hours)
ABANDONED_CART_DELAY_HOURS=1

# Daily job schedules (cron expressions)
BADGES_UPDATE_CRON=0 2 * * *       # 2 AM daily
SITEMAP_REFRESH_CRON=0 3 * * *     # 3 AM daily
ACCOUNT_DELETION_CRON=0 4 * * *    # 4 AM daily

# -------------------- GOOGLE ANALYTICS (for backend events – optional) --------------------
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your-ga4-api-secret

# -------------------- SMS NOTIFICATIONS (Optional) --------------------
# Twilio (example)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890