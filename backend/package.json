{
  "name": "marketplace-backend",
  "version": "1.0.0",
  "description": "Production marketplace backend with authentication, products, orders, advanced shipping, tax automation, A/B testing, webhooks, GDPR, affiliate, gift cards, buyer subscriptions, social features, i18n, and more.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "playwright test",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "pm2": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "logs": "pm2 logs backend",
    "build:docs": "jsdoc -c jsdoc.json"
  },
  "keywords": [
    "marketplace",
    "ecommerce",
    "express",
    "mongodb",
    "redis",
    "stripe",
    "paypal",
    "paystack",
    "coinbase",
    "i18n",
    "shipping",
    "taxjar",
    "avalara",
    "ab-testing",
    "webhooks",
    "gdpr",
    "affiliate",
    "gift-cards",
    "subscriptions",
    "social-features",
    "headless-cms",
    "seo"
  ],
  "author": "Prince Stephen Mordi",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@sentry/node": "^7.112.0",
    "@sentry/tracing": "^7.112.0",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-status-monitor": "^1.3.4",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "i18next": "^23.11.3",
    "i18next-fs-backend": "^2.3.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.4",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.13",
    "redis": "^4.6.13",
    "response-time": "^2.3.2",
    "socket.io": "^4.7.5",
    "stripe": "^15.7.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.9",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0"
  }
}